# Python Virtual Environment
# This is the most important line. It ignores your entire
# venv folder with all its thousands of files.
/.venv/

# Python Cache
# These are temporary folders Python creates
__pycache__/
*.pyc

# VSCode Editor Settings
# Ignores your personal editor settings
.vscode/
.claude/

# OS-specific files
.DS_Store
Thumbs.db

# SQLite databases (pushed to Mac mini separately, not stored in git)
*.db

# Logs
logs/*.log

# Env
.env
.env.*
